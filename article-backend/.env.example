# 数据库连接字符串（必填）
# PostgreSQL: postgresql://用户名:密码@主机:端口/数据库名?schema=public
# 推荐云数据库：Neon (neon.tech) / Supabase (supabase.com) 免费版
DATABASE_URL="postgresql://postgres:password@localhost:5432/mydb?schema=public"

# JWT 密钥（至少32位随机字符串，生产环境务必使用强随机密钥）
JWT_SECRET="your-super-secret-jwt-key-at-least-32-characters-long"

# 服务端口（本地开发用，Vercel 部署时忽略）
PORT=3000

# 前端地址（CORS 白名单，多个用逗号分隔）
# 本地开发：http://localhost:5173
# Vercel 部署：https://你的前端域名.vercel.app
FRONTEND_URL="http://localhost:5173"

# 运行环境：development | production
NODE_ENV=development

# Vercel Blob 存储令牌（图片上传功能，Vercel 部署时需要）
# 在 Vercel Dashboard > Storage > Blob 中创建后自动获取
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"
