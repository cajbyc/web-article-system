// Prisma Schema for 多角色文章管理系统
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique
  password  String    // bcrypt 哈希值
  nickname  String
  email     String    @unique
  avatar    String?   // 头像 URL
  role      String    @default("user") // admin | author | user
  status    Boolean   @default(true)   // true=启用, false=禁用
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  articles  Article[]
  comments  Comment[]
  likes     Like[]
  collects  Collect[]
  roleApplications RoleApplication[]

  @@map("users")
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  sort     Int       @default(0)
  articles Article[]

  @@map("categories")
}

model Article {
  id           Int        @id @default(autoincrement())
  title        String
  content      String     @db.Text
  cover        String?    // 封面图片 URL
  categoryId   Int
  category     Category   @relation(fields: [categoryId], references: [id])
  status       String     @default("draft") // draft | published | private
  viewCount    Int        @default(0)
  likeCount    Int        @default(0)
  collectCount Int       @default(0)
  userId       Int
  user         User       @relation(fields: [userId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  comments     Comment[]
  likes        Like[]
  collects     Collect[]

  @@map("articles")
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String   @db.Text
  articleId Int
  article   Article  @relation(fields: [articleId], references: [id])
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@map("comments")
}

model Like {
  id        Int      @id @default(autoincrement())
  userId    Int
  articleId Int
  user      User     @relation(fields: [userId], references: [id])
  article   Article  @relation(fields: [articleId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, articleId])

  @@map("likes")
}

model Collect {
  id        Int      @id @default(autoincrement())
  userId    Int
  articleId Int
  user      User     @relation(fields: [userId], references: [id])
  article   Article  @relation(fields: [articleId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, articleId])

  @@map("collects")
}

model RecycleBin {
  id        Int      @id @default(autoincrement())
  title     String
  content   String?  @db.Text
  cover     String?
  status    String?
  categoryId Int?
  userId    Int
  articleId Int
  deleteAt  DateTime @default(now())

  @@map("recycle_bin")
}

model OperationLog {
  id        Int      @id @default(autoincrement())
  operator  String   // 操作人用户名
  content   String   @db.Text // 操作描述
  ip        String?  // 操作 IP
  createdAt DateTime @default(now())

  @@map("operation_logs")
}

model Notification {
  id         Int      @id @default(autoincrement())
  userId     Int      // 接收通知的用户
  type       String   // application_approved | application_rejected | comment_reply | system
  title      String   // 通知标题
  content    String   @db.Text // 通知内容
  isRead     Boolean  @default(false)
  relatedId  Int?     // 关联的 ID（如文章ID、申请ID）
  createdAt  DateTime @default(now())

  @@map("notifications")
}

model RoleApplication {
  id          Int       @id @default(autoincrement())
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  fromRole    String    // 原角色
  toRole      String    // 申请的目标角色
  reason      String    @default("") // 申请理由
  status      String    @default("pending") // pending | approved | rejected
  reviewedBy  Int?      // 审批人 ID
  reviewNote  String    @default("") // 审批备注
  createdAt   DateTime  @default(now())
  reviewedAt  DateTime?

  @@map("role_applications")
}
